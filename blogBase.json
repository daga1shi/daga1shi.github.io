5f0f\u6295\u5165\u4f7f\u7528\u4e86\n\u4e5f\u8bb8\u4ee5\u540e\u4e0d\u4f1a\u8fd9\u4e48\u5e73\u51e1\u7684\u6bcf\u5929\u66f4\u65b0\u535a\u5ba2\n\u8bf4\u5b9e\u8bdd\uff0c\u6211\u662f\u771f\u4ee5\u4e3a\u8fd9\u6b21\u7efc\u8bc4\u65e0\u671b\u4e86\uff0c\u7ed3\u679c\u8fd8\u662f\u88ab\u62db\u8fdb\u96c6\u6210\u7535\u8def\u4e0e\u65b0\u80fd\u6e90\u4e86\n\u4ee5\u540e\u7684\u8def\u8be5\u600e\u4e48\u8d70\uff0c\u6211\u4e5f\u4e0d\u77e5\u9053\n\u6301\u7eed\u5b66\u4e60\uff0c\u65e0\u9650\u8fdb\u6b65\n\u8003\u8651\u4e0b\u6691\u5047\u91cc\u628a\u516d\u7ea7\u8bcd\u6c47\u8fc7\u5b8c\u4e00\u8f6e\uff0c\u7136\u540e\u518d\u5b66\u5b8c\u9ad8\u6570\u5427\n\u867d\u7136\u7269\u7406\u662f\u771f\u7684\u4e0d\u4f1a\uff0c\u4f46\u662f\u5b66\u8d77\u6765\u5c31\u597d\u4e86\u3002", "top": 0, "createdAt": 1783605862, "style": "", "script": "", "head": "", "ogImage": "https://avatars.githubusercontent.com/u/301690197?v=4&size=64", "createdDate": "2026-07-09", "dateLabelColor": "#1f883d"}, "P5": {"htmlDir": "docs/post/python-ji-chu.html", "labels": ["\u5b66\u4e60", "python"], "postTitle": "python\u57fa\u7840", "postUrl": "post/python-ji-chu.html", "postSourceUrl": "https://github.com/daga1shi/daga1shi.github.io/issues/5", "commentNum": 0, "wordCount": 927, "description": "## print\n\n### print\u4e3b\u8981\u5185\u5bb9\n\n```python\nprint('test')\n```\n\n>[!TIP]\n>\u8f93\u5165\u4ee3\u7801\u65f6\u7528\u82f1\u6587\u8f93\u5165\u6cd5\n>''\u53cc\u5f15\u53f7\u4e0d\u80fd\u4e22\uff0c\u5176\u5185\u90e8\u5185\u5bb9\u8868\u793a\u5b57\u7b26\u4e32\n\n### \u5176\u4ed6\n\n#### \u6362\u884c  \\n\n\n```python\nprint('te\\nst')\n```\n\n#### \u4e09\u5f15\u53f7 '''\u6216''' (\u5185\u90e8\u5185\u5bb9\u76f4\u63a5\u6362\u884c,\u663e\u793a\u7ed3\u679c\u4e5f\u4e3a\u6362\u884c)\n\n```python\nprint('''\u968f\n\u4fbf\n\u5199\n\u70b9\n\u4ec0\n\u4e48''')\n```\n\n#### \u5355\u53cc\u5f15\u53f7\u8f6c\u4e49 \\\n\n```python\nprint('\u5982\u679c\u60f3\u6253\\'\u8fd9\u79cd\u5b57\u7b26\u4e32\u7c7b\u578b\u7684\u5f15\u53f7\u5c31\u5728\u524d\u9762\u52a0\u53cd\u659c\u6760')\n```\n\n#### \u5b57\u7b26\u4e32\u8fde\u63a5\n\n```python\nprint('\u8fd9\u4e2a'+'\u53ef\u4ee5\u8ba9'+'\u5185\u5bb9\u8fde\u63a5\u5728\u4e00\u8d77')\n```\n\n+\u4e5f\u53ef\u4ee5\u8fde\u63a5\u53d8\u91cf\u548c\u5b57\u7b26\u4e32\n\n## \u53d8\u91cf\n\n### \u8d4b\u503c\n\n```python\na='\u6211\u559c\u6b22\u4f60'\n```\n\n### \u53d8\u91cf\u547d\u540d\u89c4\u5219\n\n#### \u53ea\u80fd\u7531\u6587\u5b57\u3001\u6570\u5b57\u3001\u4e0b\u5212\u7ebf\u7ec4\u6210\n\n#### \u4e0d\u80fd\u4ee5\u6570\u5b57\u5f00\u5934\n\n#### \u4e0b\u5212\u7ebf\u547d\u540d\u6cd5\uff0c\u5373\u7528\u4e0b\u5212\u7ebf\u4ee3\u66ff\u7a7a\u683c\n\n#### \u53d8\u91cf\u540d\u4e0d\u8981\u5360\u7528python\u7684\u5173\u952e\u5b57\n\n## \u8ba1\u7b97\n\n### \u57fa\u672c\u7b26\u53f7\n\n\u52a0+  \u51cf-  \u4e58*  \u9664/  \u4e58\u65b9** \u62ec\u53f7()  \u3010\u6309\u8fd0\u7b97\u4f18\u5148\u7ea7\u7531\u5c0f\u5230\u5927\u6392\u5217\u3011\n\n> [!TIP]\n>\n> \u9664\u53f7\u7528\u7684\u662f\u6b63\u659c\u6760\uff0c\u5373\u53f3shift\u5de6\u4fa7\u7684\n\n### \u5bfc\u5165math\n\n```python\nimport math\nmath.sin(1)\n```\n\n\u5982\u4e0a\uff0c\u5373\u5bfc\u5165math\u540e\uff0c\u7528**math.<u>\u51fd\u6570\u540d</u>\uff08\u2026\u2026\uff09**\uff0c\u5373\u53ef\u5b8c\u6210\u590d\u6742\u51fd\u6570\u7684\u8fd0\u7b97\n\n\u5728**pythonmath\u5e93\u5b98\u65b9\u6587\u6863**\u91cc\u67e5\u770b\u6240\u6709\u53ef\u7528\u7684\u51fd\u6570\n\n### \u6574\u6570\u4e0e\u6d6e\u70b9\u6570\n\n\u6570\u5b57\u4e3b\u8981\u5206\u4e3a\u4e24\u79cd\uff1a\u6574\u6570\u3001\u6d6e\u70b9\u6570\n\n\u6d6e\u70b9\u6570\uff0c\u5373\u5c0f\u6570\n\n\u5728python\u4e2d\uff0c\u4f7f\u7528\u9664\u6cd5\u4f1a\u8f93\u51fa\u6d6e\u70b9\u6570\uff08eg:2/1\u7684\u7ed3\u679c\u4e3a2.0\u800c\u975e2\uff09\n\n\u6b64\u5916\uff0cprint\u91cc\u4e0d\u80fd\u628a\u6570\u5b57\u548c\u5b57\u7b26\u4e32\u6df7\u7528\n\n\u5982\u9700\u6df7\u7528\uff0c\u9700\u8981\u5728\u6570\u5b57\u524d\u52a0str()\n\n```python\nprint('\u4e00\u5929\u5403'+str(8)+'\u987f'\uff09\n```\n\n\u5f53\u7136\u8fd9\u79cd\u60c5\u51b5\u8fd8\u662f\u6bd4\u8f83\u9002\u5408\u628a8\u76f4\u63a5\u653e\u5728 \u2019    \u2018 \u91cc\uff0c\u4f46\u662f\u5982\u679c\u8981\u8f93\u51fa\u6570\u5b57\u53d8\u91cf\u7684\u8bdd\u5f88\u53ef\u80fd\u4f1a\u5fd8\u8bb0\u8fd9\u4ef6\u4e8b\u3002", "top": 0, "createdAt": 1783664903, "style": "<style>.markdown-alert{padding:0.5rem 1rem;margin-bottom:1rem;border-left:.25em solid var(--borderColor-default,var(--color-border-default));}.markdown-alert .markdown-alert-title {display:flex;font-weight:var(--base-text-weight-medium,500);align-items:center;line-height:1;}.markdown-alert>:first-child {margin-top:0;}.markdown-alert>:last-child {margin-bottom:0;}</style><style>.markdown-alert.markdown-alert-tip {border-left-color:var(--borderColor-success-emphasis, var(--color-success-emphasis));background-color:var(--color-success-subtle);}.markdown-alert.markdown-alert-tip .markdown-alert-title {color: var(--fgColor-success,var(--color-success-fg));}</style>", "script": "", "head": "", "ogImage": "https://avatars.githubusercontent.com/u/301690197?v=4&size=64", "createdDate": "2026-07-10", "dateLabelColor": "#1f883d"}}, "singeListJson": {}, "labelColorDict": {"bug": "#d73a4a", "documentation": "#0075ca", "duplicate": "#cfd3d7", "enhancement": "#a2eeef", "good first issue": "#7057ff", "help wanted": "#008672", "invalid": "#e4e669", "python": "#1c3470", "question": "#d876e3", "wontfix": "#ffffff", "\u5b66\u4e60": "#8fad90", "\u65e5\u8bb0\u672c": "#39C5BB", "\u6d4b\u8bd5\u7528": "#aaaaaa"}, "displayTitle": "daga1shi\u7684\u7535\u5b50\u5c0f\u7a9d", "faviconUrl": "https://avatars.githubusercontent.com/u/301690197?v=4&size=64", "ogImage": "https://avatars.githubusercontent.com/u/301690197?v=4&size=64", "primerCSS": "<link href='https://mirrors.sustech.edu.cn/cdnjs/ajax/libs/Primer/21.0.7/primer.css' rel='stylesheet' />", "homeUrl": "https://daga1shi.github.io", "prevUrl": "disabled", "nextUrl": "disabled"}