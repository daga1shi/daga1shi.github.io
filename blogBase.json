5f0f\u6295\u5165\u4f7f\u7528\u4e86\n\u4e5f\u8bb8\u4ee5\u540e\u4e0d\u4f1a\u8fd9\u4e48\u5e73\u51e1\u7684\u6bcf\u5929\u66f4\u65b0\u535a\u5ba2\n\u8bf4\u5b9e\u8bdd\uff0c\u6211\u662f\u771f\u4ee5\u4e3a\u8fd9\u6b21\u7efc\u8bc4\u65e0\u671b\u4e86\uff0c\u7ed3\u679c\u8fd8\u662f\u88ab\u62db\u8fdb\u96c6\u6210\u7535\u8def\u4e0e\u65b0\u80fd\u6e90\u4e86\n\u4ee5\u540e\u7684\u8def\u8be5\u600e\u4e48\u8d70\uff0c\u6211\u4e5f\u4e0d\u77e5\u9053\n\u6301\u7eed\u5b66\u4e60\uff0c\u65e0\u9650\u8fdb\u6b65\n\u8003\u8651\u4e0b\u6691\u5047\u91cc\u628a\u516d\u7ea7\u8bcd\u6c47\u8fc7\u5b8c\u4e00\u8f6e\uff0c\u7136\u540e\u518d\u5b66\u5b8c\u9ad8\u6570\u5427\n\u867d\u7136\u7269\u7406\u662f\u771f\u7684\u4e0d\u4f1a\uff0c\u4f46\u662f\u5b66\u8d77\u6765\u5c31\u597d\u4e86\u3002", "top": 0, "createdAt": 1783605862, "style": "", "script": "", "head": "", "ogImage": "https://avatars.githubusercontent.com/u/301690197?v=4&size=64", "createdDate": "2026-07-09", "dateLabelColor": "#1f883d"}, "P5": {"htmlDir": "docs/post/python-ji-chu.html", "labels": ["\u5b66\u4e60", "python"], "postTitle": "python\u57fa\u7840", "postUrl": "post/python-ji-chu.html", "postSourceUrl": "https://github.com/daga1shi/daga1shi.github.io/issues/5", "commentNum": 0, "wordCount": 2669, "description": "## print\n\n### print\u4e3b\u8981\u5185\u5bb9\n\n```python\nprint('test')\n```\n\n>[!TIP]\n>\u8f93\u5165\u4ee3\u7801\u65f6\u7528\u82f1\u6587\u8f93\u5165\u6cd5\n>''\u53cc\u5f15\u53f7\u4e0d\u80fd\u4e22\uff0c\u5176\u5185\u90e8\u5185\u5bb9\u8868\u793a\u5b57\u7b26\u4e32\n\n### \u5176\u4ed6\n\n#### \u6362\u884c  \\n\n\n```python\nprint('te\\nst')\n```\n\n#### \u4e09\u5f15\u53f7 '''\u6216''' (\u5185\u90e8\u5185\u5bb9\u76f4\u63a5\u6362\u884c,\u663e\u793a\u7ed3\u679c\u4e5f\u4e3a\u6362\u884c)\n\n```python\nprint('''\u968f\n\u4fbf\n\u5199\n\u70b9\n\u4ec0\n\u4e48''')\n```\n\n#### \u5355\u53cc\u5f15\u53f7\u8f6c\u4e49 \\\n\n```python\nprint('\u5982\u679c\u60f3\u6253\\'\u8fd9\u79cd\u5b57\u7b26\u4e32\u7c7b\u578b\u7684\u5f15\u53f7\u5c31\u5728\u524d\u9762\u52a0\u53cd\u659c\u6760')\n```\n\n#### \u5b57\u7b26\u4e32\u8fde\u63a5\n\n```python\nprint('\u8fd9\u4e2a'+'\u53ef\u4ee5\u8ba9'+'\u5185\u5bb9\u8fde\u63a5\u5728\u4e00\u8d77')\n```\n\n+\u4e5f\u53ef\u4ee5\u8fde\u63a5\u53d8\u91cf\u548c\u5b57\u7b26\u4e32\n\n## \u53d8\u91cf\n\n### \u8d4b\u503c\n\n```python\na='\u6211\u559c\u6b22\u4f60'\n```\n\n### \u53d8\u91cf\u547d\u540d\u89c4\u5219\n\n#### \u53ea\u80fd\u7531\u6587\u5b57\u3001\u6570\u5b57\u3001\u4e0b\u5212\u7ebf\u7ec4\u6210\n\n#### \u4e0d\u80fd\u4ee5\u6570\u5b57\u5f00\u5934\n\n#### \u4e0b\u5212\u7ebf\u547d\u540d\u6cd5\uff0c\u5373\u7528\u4e0b\u5212\u7ebf\u4ee3\u66ff\u7a7a\u683c\n\n#### \u53d8\u91cf\u540d\u4e0d\u8981\u5360\u7528python\u7684\u5173\u952e\u5b57\n\n## \u8ba1\u7b97\n\n### \u57fa\u672c\u7b26\u53f7\n\n\u52a0+  \u51cf-  \u4e58*  \u9664/  \u4e58\u65b9** \u62ec\u53f7()  \u3010\u6309\u8fd0\u7b97\u4f18\u5148\u7ea7\u7531\u5c0f\u5230\u5927\u6392\u5217\u3011\n\n> [!TIP]\n>\n> \u9664\u53f7\u7528\u7684\u662f\u6b63\u659c\u6760\uff0c\u5373\u53f3shift\u5de6\u4fa7\u7684\n\n### \u5bfc\u5165math\n\n```python\nimport math\nmath.sin(1)\n```\n\n\u5982\u4e0a\uff0c\u5373\u5bfc\u5165math\u540e\uff0c\u7528**math.<u>\u51fd\u6570\u540d</u>\uff08\u2026\u2026\uff09**\uff0c\u5373\u53ef\u5b8c\u6210\u590d\u6742\u51fd\u6570\u7684\u8fd0\u7b97\n\n\u5728**pythonmath\u5e93\u5b98\u65b9\u6587\u6863**\u91cc\u67e5\u770b\u6240\u6709\u53ef\u7528\u7684\u51fd\u6570\n\n### \u6574\u6570\u4e0e\u6d6e\u70b9\u6570\n\n\u6570\u5b57\u4e3b\u8981\u5206\u4e3a\u4e24\u79cd\uff1a\u6574\u6570\u3001\u6d6e\u70b9\u6570\n\n\u6d6e\u70b9\u6570\uff0c\u5373\u5c0f\u6570\n\n\u5728python\u4e2d\uff0c\u4f7f\u7528\u9664\u6cd5\u4f1a\u8f93\u51fa\u6d6e\u70b9\u6570\uff08eg:2/1\u7684\u7ed3\u679c\u4e3a2.0\u800c\u975e2\uff09\n\n\u6b64\u5916\uff0cprint\u91cc\u4e0d\u80fd\u628a\u6570\u5b57\u548c\u5b57\u7b26\u4e32\u6df7\u7528\n\n\u5982\u9700\u6df7\u7528\uff0c\u9700\u8981\u5728\u6570\u5b57\u524d\u52a0str()\n\n```python\nprint('\u4e00\u5929\u5403'+str(8)+'\u987f'\uff09\n```\n\n\u5f53\u7136\u8fd9\u79cd\u60c5\u51b5\u8fd8\u662f\u6bd4\u8f83\u9002\u5408\u628a8\u76f4\u63a5\u653e\u5728 \u2019    \u2018 \u91cc\uff0c\u4f46\u662f\u5982\u679c\u8981\u8f93\u51fa\u6570\u5b57\u53d8\u91cf\u7684\u8bdd\u5f88\u53ef\u80fd\u4f1a\u5fd8\u8bb0\u8fd9\u4ef6\u4e8b\n## \u6ce8\u91ca\n\n```python\n#\u7528\u6765\u5199\u6ce8\u91ca\n'''\u4e09\u5f15\u53f7\u53ef\u4ee5\n\u5199\u8de8\u884c\u6ce8\u91ca\n'''\n```\n\n## \u6570\u636e\u7c7b\u578b\n\n### \u5b57\u7b26\u4e32 str\n\n#### \u5b57\u7b26\u4e32\u957f\u5ea6\n\n\u5bf9\u5b57\u7b26\u4e32\u5185\u5bb9\u4f7f\u7528  **len()**  \u53ef\u5f97\u5b57\u7b26\u4e32\u957f\u5ea6\n\n```python\nprint(len('hello'))\n#\u8f93\u51fa 5\n```\n\n#### \u7d22\u5f15\n\n```python\nprint('emerge'[3])\n#\u8f93\u51fa r\n#\u7d22\u5f15\u662f\u4ece\u96f6\u5f00\u59cb\u6570\u7684\uff0c[n]\u8f93\u51fa\u5b57\u7b26\u4e32\u7684\u7b2cn+1\u4e2a\u5b57\u7b26\uff08\u5305\u62ec\u7a7a\u683c\u548c\u5404\u79cd\u7b26\u53f7\uff09\n```\n\n### \u6570\u5b57\n\n\u6574\u6570  int\n\n\u6d6e\u70b9\u6570  float\n\n### \u5e03\u5c14\u7c7b\u578b bool\n\n\u5305\u542b\u4e24\u79cd\u503c\uff0c\u771f **True** \u548c\u5047 **False**\n\n> [!TIP]\n>\n> \u6ce8\u610f\u5927\u5199 T \u548c F\n\n### \u7a7a\u503c\u7c7b\u578b Nonetype\n\n\u6ce8\u610f\u4e5f\u8981\u5927\u5199 N \uff0c\u5199\u4f5c**None**\n\n###  type\u51fd\u6570\n\n```python\ntype(1)\n#\u53ef\u8fd4\u8fd8\uff08\uff09\u5185\u7684\u6570\u636e\u7c7b\u578b\n```\n\n## \u4ea4\u4e92\u6a21\u5f0f\n\n```python\n#\u8fdb\u5165\u4ea4\u4e92\u6a21\u5f0f\n~python3\n#\u73b0\u5728\u662f\u6253\u4e00\u884c\u6267\u884c\u4e00\u884c\n#\u9000\u51fa\nquit()\n```\n\n\u4f46\u662f\u9000\u51fa\u4ea4\u4e92\u6a21\u5f0f\u5c31\u4f1a\u6e05\u7a7a\u6240\u6709\u5185\u5bb9\uff0c\u65e0\u6cd5\u4fdd\u5b58\n\npycharm\u5229\u7528python\u63a7\u5236\u53f0\u8fdb\u5165\n\n## \u8f93\u5165 input\n\n\u4e00\u822c\u8fd9\u6837\u4f7f\u7528\n\n```python\n#\u53d8\u91cf=input('\u2026\u2026')\na=input(\u8bf7\u8f93\u5165\u4f60\u7684\u6027\u522b)\nprint('\u77e5\u9053\u4e86,\u4f60\u662f'+a)\n```\n\n> [!TIP]\n>\n> input\u8fd4\u8fd8\u7684\u4fe1\u606f\u662f\u5b57\u7b26\u4e32\n\n```python\n#\u5c06\u5b57\u7b26\u4e32\u8f6c\u5316\u4e3a\u6574\u6570\u3001\u6d6e\u70b9\u6570\nint('666')\nfloat('999.0')\n```\n\n##  \u6761\u4ef6\u8bed\u53e5 if\n\n### \u57fa\u672c\u5f62\u5f0f\n\n```python\na=float(input('\u4fbf\u8f93\u5165\u4e00\u4e2a\u6570\u5427\uff1a'))\nif a>10000:\n    print('nbnbnbnb')\nelse:\n    print('nbnbnb')\n```\n\n> [!TIP]\n>\n> \u6ce8\u610f\u7f29\u8fdb\uff0c4\u4e2a\u7a7a\u683c\n\n\u5b9e\u9645\u4e0a\uff0cif\u540e\u8ddf\u662f\u5e94\u4e3abool\uff0c\u5224\u65ad\u8bed\u53e5\u4f1a\u8f93\u51fa\u4e00\u4e2abool\n\n### \u5e38\u7528\u8fde\u63a5\u7b26\n\n1.\u7b49\u53f7 =\n\n2.\u4e0d\u7b49\u53f7 !=\n\n3.\u5c0f\u4e8e\u53f7 <\n\n4.\u5c0f\u4e8e\u7b49\u4e8e\u53f7 <=\n\n### \u5d4c\u5957\u548c\u591a\u4e2a\u6761\u4ef6\u5224\u65ad\n\n#### \u5d4c\u5957\n\n\u5229\u7528\u7f29\u8fdb\u5373\u53ef\u5b9e\u73b0\n\n#### elif\n\n\u4e0d\u7528\u7f29\u8fdb\uff0c\u4e00\u884c\u4e00\u884c\u6267\u884c\uff0c\u6267\u884c\u5230\u7b26\u5408\u6761\u4ef6\u7684\u90a3\u4e00\u884c\u505c\u6b62\n\n### \u903b\u8f91\u8fd0\u7b97\n\nand not or\n\nif\u540e\u9762\u53ef\u4ee5\u7528\u8fd9\u4e9b\n\n## \u5217\u8868\n\n```python\n #\u5b9a\u4e49\u5217\u8868\nthis_is_a_list=['a','b','c']\n\n#\u5728\u5217\u8868\u4e2d\u6dfb\u52a0\u5143\u7d20\nthis_is_a_list.append('d')\n\n#\u5728\u5217\u8868\u4e2d\u5220\u9664\u5143\u7d20\nthis_is_a_list.remove('d')\n\n#\u6c42\u5217\u8868\u7684\u5143\u7d20\u6570\u91cf\nlen(this_is_a_list)\n\n#\u901a\u8fc7\u7d22\u5f15\u83b7\u5f97\u67d0\u4e2a\u4f4d\u7f6e\u7684\u5143\u7d20\nthis_is_a_list[2]\n```\n\n> [!TIP]\n>\n> 1.append \u548c\u4e4b\u524d len \u7b49\u51fd\u6570\u540d\u7684\u8fd0\u7528\u65b9\u6cd5\u4e0d\u540c\uff0c\u4e3b\u8981\u683c\u5f0f\u4e3a **\u5bf9\u8c61.\u65b9\u6cd5\u540d.(\u2026\u2026)**\n>\n> 2.\u5217\u8868\u91cc\u53ef\u4ee5\u5b58\u5728\u4e0d\u540c\u7c7b\u578b\u7684\u5143\u7d20\n\n\n\n## \u5b57\u5178\n\n```python\n#\u5efa\u7acb\u4e00\u4e2a\u5b57\u5178\uff0c\u952e=\u503c\nupdate_time={'GrowUpShow\u5411\u65e5\u8475\u9a6c\u620f\u56e2'='7/4\uff0c\u6bcf\u5468\u516d',\n            '\u6b63\u540e\u65b9\u7684\u795e\u5a01'='7/3,\u6bcf\u5468\u4e94',\n            '\u5c3c\u53e4\u55b5\u55b5'='7/2,\u6bcf\u5468\u56db'}\n\n#\u67e5\u8be2\u6bcf\u4e2a\u952e\u7684\u503c\nupdate_time['\u5c3c\u53e4\u55b5\u55b5']\n\n#\u5143\u7ec4\uff0c\u7c7b\u4f3c\u5217\u8868\uff0c\u4f46\u662f\u4e0d\u53ef\u53d8\uff0c\u7528\u5706\u62ec\u53f7\uff0c\u53ef\u5b58\u8fdb\u5b57\u5178\u4e2d\uff0c\u8fd9\u4e2a\u6ca1\u542c\u61c2\nre0={('re0','\u6c34\u95e8\u7bc7'),\n     ('re0','\u593a\u8fd8\u7bc7')}\n     \n#\u6dfb\u52a0\u952e\u503c\u5bf9\n update_time['\u8bf4\u51fa\u4f60\u4eec\u5148\u8d70\u6211\u65ad\u540e\u7684\u5341\u5e74\u540e\u6211\u6210\u4e3a\u4e86\u4f20\u8bf4']='7/3,\u6bcf\u5468\u4e94\u2018\n     \n#\u786e\u8ba4\u952e\u662f\u5426\u5b58\u5728,\u8fd4\u8fd8bool\u503c\n'\u5bb6\u4e61\u6700\u9ad8' in update_time\n     \n#\u5220\u9664\u952e\ndel contacts['\u5c3c\u59d1\u55b5\u55b5']\n\n#\u67e5\u8be2\u6709\u591a\u5c11\u952e\u503c\u5bf9\nlen(update_time)\n```\n\n\u3002", "top": 0, "createdAt": 1783664903, "style": "<style>.markdown-alert{padding:0.5rem 1rem;margin-bottom:1rem;border-left:.25em solid var(--borderColor-default,var(--color-border-default));}.markdown-alert .markdown-alert-title {display:flex;font-weight:var(--base-text-weight-medium,500);align-items:center;line-height:1;}.markdown-alert>:first-child {margin-top:0;}.markdown-alert>:last-child {margin-bottom:0;}</style><style>.markdown-alert.markdown-alert-tip {border-left-color:var(--borderColor-success-emphasis, var(--color-success-emphasis));background-color:var(--color-success-subtle);}.markdown-alert.markdown-alert-tip .markdown-alert-title {color: var(--fgColor-success,var(--color-success-fg));}</style>", "script": "", "head": "", "ogImage": "https://avatars.githubusercontent.com/u/301690197?v=4&size=64", "createdDate": "2026-07-10", "dateLabelColor": "#1f883d"}}, "singeListJson": {}, "labelColorDict": {"bug": "#d73a4a", "documentation": "#0075ca", "duplicate":